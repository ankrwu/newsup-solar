# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/newsup_solar
SQLITE_URL=sqlite:///./data/news.db

# Redis configuration (optional)
REDIS_URL=redis://localhost:6379/0

# API configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=true

# Crawler configuration
CRAWL_INTERVAL_HOURS=6
USER_AGENT=Mozilla/5.0 (compatible; newsup-solar/1.0; +https://github.com/ankrwu/newsup-solar)
REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=5

# News sources (comma-separated)
NEWS_SOURCES=pv-magazine,solar-power-world,renewable-energy-world,cleantechnica

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Sentiment analysis
ENABLE_SENTIMENT_ANALYSIS=true
SENTIMENT_THRESHOLD=0.2

# Email notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
NOTIFICATION_EMAILS=admin@example.com

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs (optional)
NEWSAPI_KEY=your-newsapi-key
OPENAI_API_KEY=your-openai-api-key

# Monitoring
ENABLE_METRICS=true
PROMETHEUS_PORT=9090